theme = Catppuccin Frappe
macos-titlebar-style = tabs
mouse-hide-while-typing = true

# ssh wrapper: auto-install ghostty terminfo on remote hosts, fall back to
# xterm-256color where it can't ("missing or unsuitable terminal" otherwise)
shell-integration-features = ssh-env,ssh-terminfo

macos-option-as-alt = true
key-remap = cmd=option
key-remap = option=cmd

# tmux resize
keybind = option+shift+h=esc:H
keybind = option+shift+j=esc:J
keybind = option+shift+k=esc:K
keybind = option+shift+l=esc:L

# reclaim physical cmd+h from macOS's Hide menu item (see key-remap above)
keybind = option+h=esc:h

keybind = option+period=esc:.
keybind = option+v=paste_from_clipboard
keybind = cmd+zero=unbind
keybind = super+shift+enter=unbind
