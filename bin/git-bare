#!/usr/bin/env sh
set -e

usage() {
	echo "Usage: git bare {init,clone} <args>"
	exit 1
}

ensure_not_exists() {
	if [ -e "$1" ]; then
		echo "$1 already exists" >&2
		exit 1
	fi
}

cmd_init() {
	NAME="${1:?Usage: git bare init <name>}"

	ensure_not_exists "$NAME"

	git init --bare "$NAME/.git"
	git -C "$NAME" config core.logAllRefUpdates true
	git -C "$NAME" config worktree.useRelativePaths true

	BRANCH=$(git -C "$NAME" symbolic-ref --short HEAD)
	git -C "$NAME" worktree add --orphan -b "$BRANCH" "$BRANCH"
}

cmd_clone() {
	SPEC="$1"

	if [ -z "$SPEC" ]; then
		command -v fzf >/dev/null || usage
		ORG=$({ gh api user -q .login; gh api user/orgs -q '.[].login'; } | fzf --prompt="org> " --height=40%)
		[ -n "$ORG" ] || exit 1
		EXISTING=$(mktemp)
		[ -d "$ORG" ] && ls -1 "$ORG" > "$EXISTING"
		REPO=$(gh repo list "$ORG" --json name -q '.[].name' --limit 200 | grep -vFxf "$EXISTING" | fzf --prompt="$ORG/> " --height=40%)
		rm -f "$EXISTING"
		[ -n "$REPO" ] || exit 1
		SPEC="$ORG/$REPO"
	fi

	if command -v gh >/dev/null && ! printf '%s' "$SPEC" | grep -q '^\(git@\|https\?://\)'; then
		INFO=$(gh repo view "$SPEC" --json sshUrl,isFork,parent,name,owner)
		URL=$(printf '%s' "$INFO" | jq -r .sshUrl)
		DEFAULT_NAME=$(printf '%s' "$INFO" | jq -r '.owner.login + "/" + .name')
	else
		URL="$SPEC"
		INFO=""
		DEFAULT_NAME=$(basename "$URL" .git)
	fi
	NAME="${2:-$DEFAULT_NAME}"

	ensure_not_exists "$NAME"

	git clone --bare "$URL" "$NAME/.git"
	git -C "$NAME" config core.logAllRefUpdates true
	git -C "$NAME" config worktree.useRelativePaths true

	if [ -n "$INFO" ] && [ "$(printf '%s' "$INFO" | jq -r .isFork)" = "true" ]; then
		PARENT_URL="git@github.com:$(printf '%s' "$INFO" | jq -r .parent.owner.login)/$(printf '%s' "$INFO" | jq -r .parent.name).git"
		git -C "$NAME" remote add upstream "$PARENT_URL"
	fi

	BRANCH=$(git -C "$NAME" symbolic-ref --short HEAD)
	# Fetch into refs/remotes (never refs/heads, which a bare clone would
	# clobber) for ALL branches, so origin/<branch> exists everywhere and
	# argless --force-with-lease works
	git -C "$NAME" config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"
	git -C "$NAME" fetch origin
	git -C "$NAME" worktree add "$BRANCH"
}

COMMAND="${1:-}"
shift || usage

case "$COMMAND" in
	init) cmd_init "$@" ;;
	clone) cmd_clone "$@" ;;
	*) usage ;;
esac
